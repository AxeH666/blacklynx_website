{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": ".test-dist",
    "rootDir": ".",
    "noEmit": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
